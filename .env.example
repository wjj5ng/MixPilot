# MixPilot 환경 설정 예시. 실제 값은 `.env`에 복사 후 수정.
# (.env는 gitignore 대상이므로 머신·환경 별로 다른 값 OK)

# === Audio capture (ADR-0004 — M32 USB 직접 캡처) ===
# 운영 시작 토글. false면 서버는 뜨지만 오디오·추천 파이프라인은 비활성.
MIXPILOT_AUDIO__ENABLED=false
MIXPILOT_AUDIO__DEVICE_SUBSTRING=M32
MIXPILOT_AUDIO__SAMPLE_RATE=48000
MIXPILOT_AUDIO__BLOCK_SIZE=512
MIXPILOT_AUDIO__NUM_CHANNELS=32

# === M32 console control (ADR-0005 — X32 OSC over UDP) ===
MIXPILOT_M32__HOST=192.168.1.100
MIXPILOT_M32__PORT=10023
# dry-run | assist | auto  (디폴트: dry-run)
MIXPILOT_M32__OPERATING_MODE=dry-run
MIXPILOT_M32__AUTO_APPLY_CONFIDENCE_THRESHOLD=0.95

# === Category LUFS targets (EBU R128 integrated, ~400ms+ buffer 필요) ===
MIXPILOT_LUFS__VOCAL=-16.0
MIXPILOT_LUFS__PREACHER=-18.0
MIXPILOT_LUFS__CHOIR=-20.0
MIXPILOT_LUFS__INSTRUMENT=-22.0
MIXPILOT_LUFS__UNKNOWN=-23.0

# === Category RMS dBFS targets (라이브 프레임 단위 분석용) ===
# LUFS 대비 보통 2~3 dB 낮음 (K-weighting boost 보정).
MIXPILOT_RMS_DBFS__VOCAL=-18.0
MIXPILOT_RMS_DBFS__PREACHER=-20.0
MIXPILOT_RMS_DBFS__CHOIR=-22.0
MIXPILOT_RMS_DBFS__INSTRUMENT=-24.0
MIXPILOT_RMS_DBFS__UNKNOWN=-26.0

# === Live LUFS 분석 (롤링 버퍼 + 주기 평가, 디폴트 비활성) ===
MIXPILOT_LUFS_ANALYSIS__ENABLED=false
MIXPILOT_LUFS_ANALYSIS__BUFFER_SECONDS=1.0
MIXPILOT_LUFS_ANALYSIS__EVAL_INTERVAL_FRAMES=50

# === Live Feedback (하울링) 감지 (채널별 detector, 디폴트 비활성) ===
MIXPILOT_FEEDBACK_ANALYSIS__ENABLED=false
MIXPILOT_FEEDBACK_ANALYSIS__PNR_THRESHOLD_DB=15.0
MIXPILOT_FEEDBACK_ANALYSIS__PERSISTENCE_FRAMES=3
MIXPILOT_FEEDBACK_ANALYSIS__MIN_FREQUENCY_HZ=100.0
MIXPILOT_FEEDBACK_ANALYSIS__MAX_FREQUENCY_HZ=8000.0

# === Channel mapping file ===
MIXPILOT_CHANNEL_MAP_PATH=config/channels.yaml
